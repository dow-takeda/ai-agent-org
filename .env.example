ANTHROPIC_API_KEY=your-api-key-here

# パイプライン設定
MAX_ROLLBACK_ATTEMPTS=3
MAX_DISCUSSION_ROUNDS=2
ENGINEER_COUNT=1
REVIEWER_COUNT=1
THINKING_BUDGET_TOKENS=10000

# デフォルトパーソナリティ（未指定時はなし）
# DEFAULT_PM_PERSONALITY=visionary
# DEFAULT_ENGINEER_PERSONALITY=performance
# DEFAULT_REVIEWER_PERSONALITY=correctness

# デフォルト口調（未指定時は onee）
DEFAULT_PM_TONE=onee
DEFAULT_ENGINEER_TONE=onee
DEFAULT_REVIEWER_TONE=onee

# Docker sandbox (docker compose 用)
# SOURCE_PATH=/path/to/target/source
